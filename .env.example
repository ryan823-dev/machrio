# Environment Variables
# Copy this file to .env.local and fill in the values

# Payload CMS Secret (generate a random 32+ character string)
PAYLOAD_SECRET=your-secret-key-here-change-in-production

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/machrio

# Public URL (used for sitemap, canonical URLs, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email Service (Resend)
RESEND_API_KEY=your-resend-api-key

# RFQ Notification Email
RFQ_NOTIFICATION_EMAIL=sales@machrio.com

# AI Assistant Configuration
# Choose one provider and add its API key
AI_PROVIDER=openrouter  # Options: openrouter, openai, anthropic

# OpenRouter (recommended - access to multiple models)
OPENROUTER_API_KEY=your-openrouter-api-key

# OR OpenAI
# OPENAI_API_KEY=your-openai-api-key

# OR Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Override default model
# AI_MODEL=anthropic/claude-3.5-sonnet
