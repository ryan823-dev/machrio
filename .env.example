# =============================================
# Machrio Environment Variables
# =============================================

# Payload CMS Secret (32+ characters)
PAYLOAD_SECRET=your-secret-key-here

# =============================================
# Database Configuration
# =============================================
# Option 1: MongoDB (deprecated)
# MONGODB_URI=mongodb+srv://user:password@host/machrio

# Option 2: PostgreSQL via Supabase
USE_POSTGRES=0  # Set to 1 when ready to use PostgreSQL
DATABASE_URI=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# =============================================
# Supabase (optional - for Auth/Storage)
# =============================================
# NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================
# Public URL
# =============================================
# Development (local)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Production (primary domain without www)
# NEXT_PUBLIC_SERVER_URL=https://machrio.com

# =============================================
# Email Service
# =============================================
RESEND_API_KEY=your-resend-api-key
RFQ_NOTIFICATION_EMAIL=sales@machrio.com

# =============================================
# AI Provider
# =============================================
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key

# =============================================
# Storage (Vercel Blob)
# =============================================
BLOB_READ_WRITE_TOKEN=your-blob-token

# =============================================
# Payment (PayPal)
# =============================================
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# =============================================
# Shipping (Aliyun OSS)
# =============================================
ALIYUN_OSS_REGION=oss-us-west-1
ALIYUN_OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com
ALIYUN_OSS_BUCKET=machrio
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key
ALIYUN_OSS_ACCESS_KEY_SECRET=your-secret-key

# =============================================
# AI Conversation Tracking (Admin Backend)
# =============================================
# Admin backend API URL for saving AI conversations
NEXT_PUBLIC_ADMIN_API_URL=https://admin-api.machrio.com
# Optional: API key for authentication
NEXT_PUBLIC_ADMIN_API_KEY=your-admin-api-key
