# =============================================
# Machrio Environment Variables (Railway)
# =============================================

# Payload CMS Secret (32+ characters)
PAYLOAD_SECRET=your-secret-key-here

# =============================================
# Database Configuration (PostgreSQL)
# =============================================
# Canonical runtime variable. The app server reads DATABASE_URI directly.
DATABASE_URI=postgresql://postgres:password@host:5432/railway
# If your platform injects DATABASE_URL automatically, copy the same value into
# DATABASE_URI as well. DATABASE_URL alone is not enough for all runtime paths.
# DATABASE_URL=postgresql://postgres:password@host:5432/railway

# =============================================
# Public URL
# =============================================
# Development (local)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Production
# NEXT_PUBLIC_SERVER_URL=https://machrio.com

# =============================================
# Email Service (Resend)
# =============================================
RESEND_API_KEY=your-resend-api-key
RFQ_NOTIFICATION_EMAIL=support@machrio.com

# =============================================
# AI Router
# =============================================
# Primary route: OpenAI GPT-5.4
# Backup route: GLM-5 via a Qwen-planning gateway or GLM-compatible endpoint
AI_ROUTER_PRIMARY=openai
AI_ROUTER_BACKUP=glm
AI_TIMEOUT_MS=12000
AI_FALLBACK_TIMEOUT_MS=12000

# OpenAI (primary)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4
# OPENAI_BASE_URL=https://api.openai.com/v1

# GLM backup
# If you are routing GLM-5 through a Qwen planning service, point QWEN_PLAN_BASE_URL
# at an OpenAI-compatible /v1 endpoint and set QWEN_PLAN_MODEL to whatever that
# gateway expects. If you call GLM directly, use GLM_BASE_URL / GLM_API_KEY instead.
QWEN_PLAN_BASE_URL=https://your-qwen-plan-gateway.example.com/v1
QWEN_PLAN_API_KEY=your-qwen-plan-api-key
# QWEN_PLAN_MODEL=glm-5

# GLM_BASE_URL=https://your-glm-compatible-endpoint.example.com/v1
# GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-5

# Legacy compatibility only
# AI_PROVIDER=openrouter
# AI_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_API_KEY=your-openrouter-api-key

# =============================================
# Payment (PayPal)
# =============================================
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# =============================================
# Payment (Stripe)
# =============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# =============================================
# Storage (Aliyun OSS)
# =============================================
ALIYUN_OSS_REGION=oss-us-west-1
ALIYUN_OSS_ENDPOINT=https://oss-us-west-1.aliyuncs.com
ALIYUN_OSS_BUCKET=machrio
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key
ALIYUN_OSS_ACCESS_KEY_SECRET=your-secret-key

# =============================================
# Analytics (Google)
# =============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-ga-measurement-id
