    "title": "How to Choose the Right Respirator for Your Job",
    "slug": "how-to-choose-respirator-for-your-job",
    "content": "{\"root\":{\"type\":\"root\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Choosing the wrong respirator can be just as dangerous as wearing none at all.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"The right choice depends on three things: what you are breathing, how much of it, and how long you are exposed.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"This guide walks you through the selection process step by step.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Quick Decision Flowchart\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h2\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Use this logic to narrow your options fast:\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"1. Is oxygen below 19.5% or the atmosphere IDLH?\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ Yes: You need supplied-air (SAR or SCBA). Stop here.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ No: Continue to step 2.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"2. Is the hazard a gas, vapor, or combination?\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ Gas/vapor only: Half-face or full-face with chemical cartridges.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ Particulate only: N95, P100, or elastomeric with particulate filter.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ Combination: Use combo cartridges (e.g., OV/P100).\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"3. Calculate your required APF.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ APF ≤ 10: Half-face or N95 disposable.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ APF 11–50: Full-face or tight-fitting PAPR.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ APF > 50: Supplied-air or SCBA.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"4. Do you need eye protection from the same hazard?\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ Yes: Full-face, PAPR with hood, or supplied-air.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"→ No: Half-face is acceptable if APF allows.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Respirator Types at a Glance\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h2\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Each type serves a different protection range and use case.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Disposable Filtering Facepiece (N95, P100)\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h3\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"APF: 10.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Best for: Low-concentration particulate hazards like construction dust, drywall, healthcare airborne precautions, and wildfire smoke.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Limitations: No gas/vapor protection. Not oil-resistant (N series). Cannot be fit-tested with facial hair. Single use.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Elastomeric Half-Face Respirator\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h3\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"APF: 10.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Best for: Recurring chemical or particulate exposures where reusable equipment is cost-effective. Paint spraying, pesticide application, solvent work, welding fumes.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Advantages over disposables: Replaceable cartridges, better seal, more comfortable for repeated use, lower long-term cost.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Elastomeric Full-Face Respirator\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h3\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"APF: 50.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Best for: Higher-concentration hazards requiring eye protection. Asbestos abatement, lead paint removal, chemical splash environments, silica exposure.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Key benefit: Five times the protection factor of a half-face, plus integrated eye and face coverage.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Powered Air-Purifying Respirator (PAPR)\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h3\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"APF: 25 (loose-fitting) to 1,000 (helmet/hood).\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Best for: Extended wear, workers with facial hair, workers who fail fit tests, pharmaceutical and healthcare isolation.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Key benefit: Battery-powered fan reduces breathing effort. Loose-fitting options eliminate fit testing.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Supplied-Air Respirator (SAR)\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h3\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"APF: 50 (half-face) to 1,000 (full facepiece, pressure-demand).\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Best for: IDLH environments, oxygen-deficient spaces, sandblasting, spray painting with isocyanates.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Limitation: Tethered to airline. Limited mobility.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Self-Contained Breathing Apparatus (SCBA)\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"tag\":\"h3\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"APF: 10,000 (pressure-demand full facepiece).\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Best for: Emergency response, firefighting, confined space rescue, chemical spill entry.\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"mode\":\"normal\",\"text\":\"Limitation: Heavy. Limited air supply duration (30–60 minutes typical).\",\"type\":\"text\",\"format\":0,\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"format\":\"\",\"indent\":0,\"ver