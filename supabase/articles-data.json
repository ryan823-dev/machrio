rmat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"format\":\"\",\"indent\":0,\"version\":1,\"listType\":\"bullet\",\"start\":1,\"tag\":\"ul\",\"direction\":\"ltr\",\"children\":[{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Written respiratory protection program\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Medical evaluation before fit testing\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Annual fit testing for tight-fitting respirators\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Training on use, limitations, and maintenance\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Proper storage and maintenance procedures\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"}]},{\"type\":\"heading\",\"tag\":\"h2\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"type\":\"text\",\"text\":\"Key Takeaways\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"list\",\"format\":\"\",\"indent\":0,\"version\":1,\"listType\":\"bullet\",\"start\":1,\"tag\":\"ul\",\"direction\":\"ltr\",\"children\":[{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Respirators vary enormously — one type does not fit all hazards\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Match the respirator APF to your calculated exposure\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Air-purifying respirators require adequate oxygen and sub-IDLH levels\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Chemical cartridges are contaminant-specific\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"listitem\",\"format\":\"\",\"indent\":0,\"version\":1,\"value\":1,\"children\":[{\"type\":\"text\",\"text\":\"Fit testing is mandatory for tight-fitting respirators\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"}]},{\"type\":\"heading\",\"tag\":\"h2\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"type\":\"text\",\"text\":\"Next Steps\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"type\":\"text\",\"text\":\"Browse our \",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1},{\"type\":\"text\",\"text\":\"Respiratory Protection\",\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1},{\"type\":\"text\",\"text\":\" category for NIOSH-certified respirators.\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"type\":\"text\",\"text\":\"We carry everything from N95 disposables to full-face and PAPR systems.\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"format\":\"\",\"indent\":0,\"version\":1,\"children\":[{\"type\":\"text\",\"text\":\"Need help selecting the right respirator? Use our \",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1},{\"type\":\"text\",\"text\":\"AI Sourcing Assistant\",\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1},{\"type\":\"text\",\"text\":\" or \",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1},{\"type\":\"text\",\"text\":\"request a quote\",\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1},{\"type\":\"text\",\"text\":\".\",\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"detail\":0,\"version\":1}],\"direction\":\"ltr\",\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":\"ltr\"}}",
